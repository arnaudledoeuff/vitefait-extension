{
  "manifest_version": 3,
  "name": "vitefait.io — Screen Recorder",
  "version": "1.0.0",
  "description": "Démarre et arrête tes enregistrements vitefait.io depuis n'importe quel onglet.",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
